{
  "manifest_version": 3,
  "name": "DigestPage",
  "version": "1.0.0",
  "description": "Extract and summarize webpage content with ChatGPT using custom prompts",
  "permissions": [
    "storage",
    "activeTab",
    "scripting"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["https://chat.openai.com/*", "https://chatgpt.com/*"],
      "js": ["chatgpt-inject.js"],
      "run_at": "document_idle"
    }
  ],
  "commands": {
    "clip-to-chat": {
      "suggested_key": {
        "default": "Ctrl+Shift+Y",
        "mac": "Command+Shift+Y"
      },
      "description": "Digest page content and open ChatGPT"
    }
  }
}
